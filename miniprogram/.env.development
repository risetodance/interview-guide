# 微信小程序环境变量配置

# 开发环境 - 后端API地址
# 开发时使用本地后端服务
VITE_API_BASE_URL=http://localhost:8080/api

# Mock数据开关（开发测试用）
VITE_MOCK_ENABLED=false

# 生产环境 - 后端API地址
# VITE_API_BASE_URL=https://api.interview-guide.com

# WebSocket地址
# VITE_WS_URL=ws://localhost:8080/ws

# 微信小程序AppID（开发时使用测试号）
# VITE_WECHAT_APPID=your_appid_here
